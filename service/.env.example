# Copy to .env and adjust for your environment: cp .env.example .env

# --- Auth ---
JWT_SECRET=please-change-this-to-a-long-random-string
JWT_EXPIRE_MINUTES=1440
SEED_DEFAULT_USERS=true

# --- MongoDB ---
MONGO_URI=mongodb://mongo:27017
MONGO_DB=assetforge

# --- MinIO (S3-compatible object storage for image binaries) ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=assets
MINIO_SECURE=false

# --- Redis / Celery (async worker pool) ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- ComfyUI (GPU inference) ---
# Real GPU inference is the default. ComfyUI is built from the official upstream
# repository and started automatically by docker compose.
COMFYUI_URL=http://comfyui:8188
COMFYUI_TIMEOUT=600
COMFYUI_MOCK=false

# --- Ollama (local LLM prompt expansion) ---
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b

# --- CORS (frontend talks through the nginx proxy, so * is safe here) ---
CORS_ORIGINS=*

# --- Model provisioning (HuggingFace downloader) ---
# Space separated list of HuggingFace "repo_id:filename" entries to fetch.
# For private repositories, provide HF_TOKEN from https://huggingface.co/settings/tokens
HF_TOKEN=

# Anima Base (Cosmos2 architecture) components
BASE_MODELS=SkyHonor/Anima:anima-base-v1.0.safetensors SkyHonor/Anima:qwen_3_06b_base.safetensors SkyHonor/Anima:qwen_image_vae.safetensors

# LoRA weights (turbo acceleration + style LoRAs)
LORA_MODELS=SkyHonor/Acceleration_Lora:anima-turbo-lora-v0.2.safetensors SkyHonor/Prototype:SlyToon-Anima-v1.safetensors SkyHonor/Prototype:SpellIcons-Anima-v1.safetensors

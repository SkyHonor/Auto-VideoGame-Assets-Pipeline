# Copy to .env and adjust for your environment: cp .env.example .env

# --- Auth ---
JWT_SECRET=please-change-this-to-a-long-random-string
JWT_EXPIRE_MINUTES=1440
SEED_DEFAULT_USERS=true

# --- MongoDB ---
MONGO_URI=mongodb://mongo:27017
MONGO_DB=assetforge

# --- MinIO (S3-compatible object storage for image binaries) ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=assets
MINIO_SECURE=false

# --- Redis / Celery (async worker pool) ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- ComfyUI (GPU inference) ---
# Set COMFYUI_MOCK=false and start the "gpu" profile to use a real ComfyUI server.
COMFYUI_URL=http://comfyui:8188
COMFYUI_TIMEOUT=600
COMFYUI_MOCK=true

# --- Ollama (local LLM prompt expansion) ---
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b

# --- CORS (frontend talks through the nginx proxy, so * is safe here) ---
CORS_ORIGINS=*

# --- Model provisioning (base-downloader) ---
# Space separated list of HuggingFace "repo_id:filename" checkpoints to fetch.
HF_TOKEN=
BASE_MODELS=stabilityai/stable-diffusion-xl-base-1.0:sd_xl_base_1.0.safetensors
